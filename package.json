{
  "name": "massage-website",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 --turbopack",
    "build": "next build",
    "start": "next start",
    "preview": "next start --hostname 127.0.0.1 --port 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:baseline": "start-server-and-test \"npm run preview\" http://127.0.0.1:3000 \"playwright test tests/e2e/a11y-smoke.spec.ts --project=desktop-chrome --project=mobile-safari\"",
    "test:e2e:baseline:ci": "npm run build && mkdir -p ./test-results && start-server-and-test \"npm run preview\" http://127.0.0.1:3000 \"playwright test tests/e2e/a11y-smoke.spec.ts --project=desktop-chrome --project=mobile-safari --reporter=json > ./test-results/playwright-baseline.json\"",
    "perf:lighthouse": "npm run perf:lighthouse:desktop && npm run perf:lighthouse:mobile",
    "perf:lighthouse:desktop": "start-server-and-test \"npm run preview\" http://127.0.0.1:3000 \"node ./scripts/run-lighthouse.mjs desktop\"",
    "perf:lighthouse:mobile": "start-server-and-test \"npm run preview\" http://127.0.0.1:3000 \"node ./scripts/run-lighthouse.mjs mobile\"",
    "perf:lighthouse:baseline": "npm run build && npm run perf:lighthouse && node ./scripts/verify-lighthouse-thresholds.mjs"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@vercel/analytics": "^2.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.1.2",
    "lucide-react": "^0.553.0",
    "next": "^16.1.1",
    "next-safe-action": "^8.0.11",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "redis": "^5.9.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^16.1.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.17",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "baseline-browser-mapping": "^2.10.10",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "lighthouse": "^12.8.2",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "start-server-and-test": "^3.0.0",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
